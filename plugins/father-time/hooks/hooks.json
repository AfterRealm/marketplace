{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/time_inject.py\"",
            "statusMessage": "Checking time..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/compaction_warn.py\"",
            "statusMessage": "Checking context..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/session_start.py\"",
            "statusMessage": "Starting session timer..."
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/update_check.py\"",
            "statusMessage": "Checking for updates..."
          }
        ]
      }
    ]
  }
}
